# LLM Visibility Dashboard — API keys
# Copy this file to /home/ubuntu/Uplers-llm-visibility/.env on the VM
# and fill in the keys you have. Leave blank for LLMs you don't use.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=

# Optional — disable any LLM by setting to "false"
ENABLE_CHATGPT=true
ENABLE_CLAUDE=true
ENABLE_GEMINI=true
ENABLE_GROK=true
ENABLE_PERPLEXITY=true
